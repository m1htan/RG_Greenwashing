# =============================================================================
# RG_Greenwashing — copy to config/.env and fill values
# Load order: config/.env first, then .env at repo root (fallback).
# =============================================================================

# --- Gemini (scripts/extract_esg_fields.py) ---
# Bắt buộc một trong hai: GEMINI_API_KEY (khuyến nghị) hoặc GOOGLE_API_KEY.
# Tránh để trùng cả hai — nếu cả hai có, SDK Google từng in cảnh báo (script đã giảm).
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Model IDs (Google AI)
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_BATCH=gemini-2.5-flash

# Sampling (0 = deterministic)
GEMINI_TEMPERATURE=0.0

# First N PDFs (sorted by filename) use GEMINI_MODEL_PRO; rest use GEMINI_MODEL_BATCH
GEMINI_SAMPLE_PRO_N=5

# Claims / evidence limits (prompt + post-truncation)
GEMINI_MAX_CLAIMS=10
GEMINI_MAX_QUOTE_CHARS=500

# Seconds between API calls
GEMINI_DELAY_SECONDS=2.0

# Paths (relative to repo root or absolute)
GEMINI_PDF_DIR=data/vietnam_sustainabilityreports/pdfs
GEMINI_REPORTS_JSON=data/vietnam_sustainabilityreports/vietnam_reports.json
GEMINI_COMPANIES_JSON=data/vietnam_sustainabilityreports/vietnam_companies.json
GEMINI_OUTPUT_CSV=data/esg_extracted.csv
# JSONL: một dòng = một báo cáo (claims là mảng). Bật/tắt ghi JSONL:
GEMINI_WRITE_JSONL=true
# Tuỳ chọn: đường dẫn riêng; để trống = cùng tên với GEMINI_OUTPUT_CSV đổi .jsonl
# GEMINI_JSONL_OUTPUT=data/esg_extracted.jsonl

# PyMuPDF: cảnh báo PDF scan/thiếu chữ nếu trung bình ký tự/trang < ngưỡng
GEMINI_LOW_TEXT_CHARS_PER_PAGE=80

GEMINI_PROMPT_FILE=config/esg_extraction_prompt.txt
GEMINI_LOG_FILE=logs/extraction.log

# true/false — resume CSV
GEMINI_SKIP_EXISTING=false

# Optional: cap number of PDFs (leave empty = unlimited)
# GEMINI_MAX_FILES=

# --- Crawl (scripts/crawl_vietnam_sustainability_reports.py) ---
CRAWL_OUT_DIR=data/vietnam_sustainabilityreports
CRAWL_API_BASE=https://srdp-api-gah6f2asbedwagbp.westeurope-01.azurewebsites.net

CRAWL_PER_PAGE_COMPANIES=200
CRAWL_PER_PAGE_REPORTS=50

# true/false
CRAWL_DOWNLOAD_PDFS=false
CRAWL_SKIP_EXISTING_PDFS=false
CRAWL_HEADLESS=false

# Optional limit for debug (empty = all companies)
# CRAWL_MAX_COMPANIES=

CRAWL_LOG_LEVEL=INFO
# Optional: leave empty to log only to stderr
# CRAWL_LOG_FILE=logs/crawl.log
